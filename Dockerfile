# Використовуємо офіційний образ Node.js
FROM node:18

# Створюємо робочу директорію в контейнері
WORKDIR /usr/src/app

# Копіюємо файли залежностей
COPY package*.json ./

# Встановлюємо залежності
RUN npm install

# Копіюємо всі інші файли проєкту
COPY . .

# Відкриваємо порт (зазвичай 3000)
EXPOSE 3000

# Команда для запуску додатка
CMD ["npm", "start"]